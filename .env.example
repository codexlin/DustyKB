# DashScope OpenAI-compatible key（阿里云百炼）
# 任选其一即可；两者都填时优先使用 OPENAI_API_KEY
OPENAI_API_KEY=sk-your-dashscope-key
DASHSCOPE_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
CHAT_MODEL=qwen-plus
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=10
RERANK_ENABLED=true
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
RERANK_MODEL=qwen3-rerank
RETRIEVE_TOP_K=20
RERANK_TOP_K=6

# Hybrid retrieval: Qdrant dense + local BM25 + RRF
HYBRID_ENABLED=true
BM25_TOP_K=20
RRF_K=60

# --- Local development (uvicorn / pnpm dev) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=kb_chunks
DATA_DIR=./data
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql://kb_user:kb_password@localhost:5432/kb_system

# --- Docker Compose overrides (set in docker-compose.yml, listed here for reference) ---
# QDRANT_URL=http://qdrant:6333
# DATABASE_URL=postgresql://kb_user:kb_password@postgres:5432/kb_system
# DATA_DIR=/app/data
# CORS_ORIGINS=http://localhost:3000

# --- Dokploy (docker-compose.dokploy.yml: API only, Traefik → api.verogeo.com) ---
# POSTGRES_PASSWORD=kb_password
# CORS_ORIGINS=https://your-frontend.vercel.app
# OPENAI_API_KEY / DASHSCOPE_API_KEY still required

# --- Vercel frontend ---
# NEXT_PUBLIC_API_URL=https://api.verogeo.com

# 若改用 DeepSeek 生成，可改为：
# OPENAI_BASE_URL=https://api.deepseek.com
# CHAT_MODEL=deepseek-chat
# 注意：Embedding 仍建议用通义；混用时请拆成两套客户端（后续可加）
